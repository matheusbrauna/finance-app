// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id     String   @id @default(uuid())
  title  String
  amount Int
  date   DateTime @default(now())
  type   Type

  @@map("transactions")
}

model Category {
  id         String @id @default(uuid())
  title      String
  amount     Int?
  percentage Int

  @@map("categories")
}

enum Type {
  income
  outcome
}
