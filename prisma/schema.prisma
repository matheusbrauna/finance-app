// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider     = "mysql"
    url          = env("DATABASE_URL")
    relationMode = "prisma"
}

model Transaction {
    id      String   @id @default(uuid())
    user_id String
    title   String
    amount  Int
    date    DateTime @default(now())
    type    Type

    @@index([user_id])
    @@map("transactions")
}

model Category {
    id         String   @id @default(uuid())
    user_id    String?
    title      String
    amount     Int?     @default(0)
    percentage Int
    createdAt  DateTime @default(now())

    @@index([user_id])
    @@map("categories")
}

enum Type {
    income
    outcome
}
